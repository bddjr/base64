{
  "name": "@bddjr/base64",
  "version": "2.0.0",
  "description": "A high-performance Base64 and Base64url library, featuring automatic native API acceleration, and support for custom alphabets.",
  "type": "module",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./make": {
      "types": "./dist/make.d.ts",
      "default": "./dist/make.js"
    }
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "test": "npm run build && npm run test-only",
    "test-only": "node scripts/test.mjs && node scripts/test-buffer.mjs && node scripts/test-fallback.mjs",
    "test-only-node12":"node --experimental-modules scripts/test.mjs && node --experimental-modules scripts/test-fallback.mjs",
    "prepublishOnly": "npm test"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bddjr/base64.git"
  },
  "keywords": [
    "base64",
    "base",
    "encode",
    "decode",
    "atob",
    "btoa",
    "byte",
    "bytes",
    "typedarray",
    "uint8array",
    "performance",
    "zero-dependency"
  ],
  "author": "bddjr",
  "license": "Unlicense",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@bddjr/rimraf": "^0.1.1",
    "@types/node": "^20.0.0",
    "typescript": "^6.0.3"
  }
}