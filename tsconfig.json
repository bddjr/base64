{
  "compilerOptions": {
    "target": "es2015",
    "module": "node16",
    "types": ["node"],
    "lib": ["DOM", "ESNext.typedarrays"],
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationDir": "dist",
    "strict": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
